# Yum 외부 API 키 — 실제 값은 .env.local 에 채우세요 (gitignore됨)
# 키가 없거나 호출 실패 시 자동으로 mock 데이터로 fallback (ADR-0006 갈아끼움 패턴)

# 카카오 로컬 API (식당 텍스트 데이터)
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
# (제품 설정 → "카카오맵" 활성화 필수)
KAKAO_REST_API_KEY=

# 네이버 검색 오픈 API (식당 음식 사진)
# https://developers.naver.com → 애플리케이션 등록 → 사용 API "검색"
# (비로그인 오픈 API 서비스 환경에 사용 도메인 등록 필요)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
