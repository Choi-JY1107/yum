# Yum 외부 API 키 — 실제 값은 .env.local 에 채우세요 (gitignore됨)
# 키가 없으면 자동으로 mock 데이터로 fallback (ADR-0006 갈아끼움 패턴)

# Phase 3: 카카오 로컬 API
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=

# Phase 4 (예정): 네이버 검색 API
# https://developers.naver.com → 애플리케이션 등록 → 사용 API "검색"
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
